# Database (Neon / Supabase serverless PostgreSQL)
DATABASE_URL=""
DIRECT_URL=""

# NextAuth
AUTH_SECRET=""          # Generate with: openssl rand -base64 32
NEXTAUTH_URL=""         # http://localhost:3000 for development

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""           # sk_test_... from Stripe dashboard
STRIPE_PUBLISHABLE_KEY=""      # pk_test_... from Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # Same as above, exposed to client
STRIPE_WEBHOOK_SECRET=""       # whsec_... from: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# Uploadthing (file uploads)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Resend (transactional email)
RESEND_API_KEY=""

# Algolia (search)
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""
ALGOLIA_ADMIN_KEY=""

# Upstash Redis (rate limiting + cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
